{
  "python-envs.defaultEnvManager": "ms-python.python:conda",

  "python-envs.defaultPackageManager": "ms-python.python:conda",

  "python.analysis.autoImportCompletions": false,

  "editor.semanticHighlighting.enabled": true,

  "dataWrangler.experiments.datatypes.pyspark": true,

  "dataWrangler.experiments.autoDetectCsvDelimiter": true,

  "dataWrangler.experiments.fastCsvParsing": true,

  "dataWrangler.debug": true,

  "dataWrangler.outputRenderer.columnInsights.displayByDefault": true,

  "dataWrangler.outputRenderer.enabledTypes": {
    "numpy.ndarray": true,

    "builtins.list": true,

    "builtins.dict": true,

    "torch.Tensor": true,

    "tensorflow.python.framework.ops.EagerTensor": true,

    "xarray.core.dataarray.DataArray": true,

    "polars.dataframe.frame.DataFrame": true,

    "polars.series.series.Series": true,

    "pyspark.sql.dataframe.DataFrame": true,

    "pyspark.sql.connect.dataframe.DataFrame": true
  },

  "dataWrangler.outputRenderer.pagination.defaultSize": 25,

  // =========================================
  // THEME
  // =========================================

  "workbench.colorTheme": "Tokyo Night",

  // =========================================
  // NOTEBOOK + UI COLORS
  // =========================================

  "workbench.colorCustomizations": {
    "editor.background": "#0b1120",

    "editor.lineHighlightBackground": "#1e293b",

    "editorCursor.foreground": "#FFD700",

    "editor.selectionBackground": "#334155",

    "editor.selectionHighlightBackground": "#233a5c",

    "editor.wordHighlightBackground": "#224466",

    "editor.wordHighlightStrongBackground": "#335577",

    "activityBar.background": "#111827",

    "sideBar.background": "#0f172a",

    "terminal.background": "#0b1120",

    "statusBar.background": "#111827",

    "titleBar.activeBackground": "#111827",

    "tab.activeBackground": "#1e293b",

    "tab.hoverBackground": "#145fc7",

    "notebook.cellBorderColor": "#00FFFF",

    "notebook.selectedCellBorder": "#FFD700",

    "notebook.focusedCellBorder": "#FF69B4",

    "notebook.inactiveFocusedCellBorder": "#9370DB",

    "notebook.outputContainerBorderColor": "#00FA9A",

    "notebook.cellHoverBackground": "#1e1e3f",

    "notebookStatusSuccessIcon.foreground": "#00FF7F",

    "notebookStatusErrorIcon.foreground": "#FF4500",

    "notebook.symbolHighlightBackground": "#224466"
  },

  // =========================================
  // COLORFUL SYNTAX
  // =========================================

  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": ["variable", "meta.definition.variable"],
        "settings": {
          "foreground": "#FFD700"
        }
      },

      {
        "scope": ["variable.parameter"],
        "settings": {
          "foreground": "#FF69B4",
          "fontStyle": "italic"
        }
      },

      {
        "scope": ["entity.name.function", "support.function"],
        "settings": {
          "foreground": "#00ffff",
          "fontStyle": "bold italic"
        }
      },

      {
        "scope": ["meta.function-call"],
        "settings": {
          "foreground": "#8eff1d",
          "fontStyle": "italic"
        }
      },

      {
        "scope": ["keyword", "storage", "storage.type"],
        "settings": {
          "foreground": "#0014ec",
          "fontStyle": "bold italic"
        }
      },

      {
        "scope": ["keyword.operator"],
        "settings": {
          "foreground": "#FF1493",
          "fontStyle": "italic"
        }
      },

      {
        "scope": ["keyword.control.import", "keyword.control.from"],
        "settings": {
          "foreground": "#11cb4c",
          "fontStyle": "bold italic"
        }
      },

      {
        "scope": ["string"],
        "settings": {
          "foreground": "#43f743"
        }
      },

      {
        "scope": ["constant.numeric"],
        "settings": {
          "foreground": "#9511c1",
          "fontStyle": "bold"
        }
      },

      {
        "scope": ["comment"],
        "settings": {
          "foreground": "#ff133a",
          "fontStyle": "italic"
        }
      },

      {
        "scope": ["entity.name.type.class", "support.class"],
        "settings": {
          "foreground": "#ed16e6",
          "fontStyle": "bold italic"
        }
      },

      {
        "scope": ["entity.name.decorator", "meta.decorator"],
        "settings": {
          "foreground": "#29f1ff",
          "fontStyle": "italic"
        }
      },

      {
        "scope": [
          "punctuation.definition.parameters",
          "punctuation.section",
          "meta.brace"
        ],
        "settings": {
          "foreground": "#d30707"
        }
      }
    ]
  },

  // =========================================
  // FONT SETTINGS
  // =========================================

  "editor.fontFamily": "'Cascadia Code', 'Fira Code', Consolas",

  "editor.fontLigatures": true,

  "editor.fontSize": 14,

  "editor.lineHeight": 24,

  "terminal.integrated.fontSize": 14,

  "notebook.output.fontSize": 14,

  // =========================================
  // CUSTOM RGB CSS
  // =========================================

  "vscode_custom_css.imports": [
    "file:///C:/Users/suraj/Downloads/pylecs/Complete-Data-Science-With-Machine-Learning-And-NLP-2024-main/Complete-Data-Science-With-Machine-Learning-And-NLP-2024-main/2-Introduction/rgb-border.css"
  ],
  "python.terminal.activateEnvInCurrentTerminal": false,
  "python.terminal.activateEnvironment": false
}
